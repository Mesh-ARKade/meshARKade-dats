{
  "name": "mesharkade-dats",
  "version": "1.0.0",
  "type": "module",
  "description": "Automated DAT pipeline for Mesh ARKade — fetches, validates, and relays DATs from No-Intro, TOSEC, and Redump",
  "scripts": {
    "extract": "node scripts/extract.js",
    "validate": "node scripts/validate.js",
    "fetch:no-intro": "node scripts/fetch/no-intro.js",
    "fetch:tosec": "node scripts/fetch/tosec.js",
    "fetch:redump": "node scripts/fetch/redump.js",
    "relay": "node scripts/relay.js",
    "test": "vitest run"
  },
  "devDependencies": {
    "fast-xml-parser": "^4.5.0",
    "playwright": "^1.59.1",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  }
}
